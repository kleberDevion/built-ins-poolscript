import smtplib
from email.mime.text import MIMEText
from email.mime.multipart import MIMEMultipart

class MailServer:
    def __init__(self):
        # Mapeamento automático de hosts comuns
        self.hosts_config = {
            'gmail.com': ('smtp.gmail.com', 587),
            'yahoo.com': ('smtp.mail.yahoo.com', 587),
            'outlook.com': ('://office365.com', 587),
            'hotmail.com': ('://office365.com', 587)
        }
        self.server = None
        self.user = None

    def conn(self, provider_or_host, port=None):
        try:
            # Se for um provedor conhecido (ex: gmail.com), pega auto
            if provider_or_host in self.hosts_config:
                host, port = self.hosts_config[provider_or_host]
            else:
                host = provider_or_host
                port = port or 587

            self.server = smtplib.SMTP(host, port)
            self.server.starttls()  # Camada de segurança obrigatória
            return True
        except Exception as e:
            return {"error": "connection_error", "detail": str(e)}

    def login(self, user, password):
        try:
            self.user = user
            self.server.login(user, password)
            return True
        except Exception as e:
            return {"error": "auth_error", "detail": str(e)}

    def send(self, to, subject, body, html=False):
        try:
            # Montagem profissional da mensagem MIME
            msg = MIMEMultipart()
            msg['From'] = self.user
            msg['To'] = to
            msg['Subject'] = subject

            # Suporte a texto puro ou HTML
            mime_type = 'html' if html else 'plain'
            msg.attach(MIMEText(body, mime_type))

            self.server.send_message(msg)
            return True
        except Exception as e:
            return {"error": "send_error", "detail": str(e)}

    def quit(self):
        if self.server:
            self.server.quit()
            self.server = None

