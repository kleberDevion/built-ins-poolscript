from email.mime.multipart import MIMEMultipart
from email.mime.text import MIMEText
from email.mime.base import MIMEBase
from email import encoders
import os

class MailMessage:
    def __init__(self):
        # O "container" oficial de uma mensagem profissional
        self.msg = MIMEMultipart()

    def from_address(self, address):
        self.msg['From'] = address

    def to(self, address):
        self.msg['To'] = address

    def subject(self, title):
        self.msg['Subject'] = title

    def body(self, content, is_html=False):
        # Define se o corpo é texto puro ou HTML
        tipo = 'html' if is_html else 'plain'
        self.msg.attach(MIMEText(content, tipo))

    def attach(self, file_path):
        """
        Lógica profissional para anexar arquivos (PDF, Imagens, etc)
        """
        if not os.path.exists(file_path):
            return {"error": "file_not_found", "path": file_path}

        filename = os.path.basename(file_path)
        try:
            with open(file_path, "rb") as attachment:
                part = MIMEBase("application", "octet-stream")
                part.set_payload(attachment.read())
            
            encoders.encode_base64(part)
            part.add_header(
                "Content-Disposition",
                f"attachment; filename={filename}",
            )
            self.msg.attach(part)
            return True
        except Exception as e:
            return {"error": "attach_error", "detail": str(e)}

    def get_as_string(self):
        # Retorna a mensagem pronta para o MailServer enviar
        return self.msg
